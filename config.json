  "bytetrack_match_thresh": 0.7,
  "log_dir": "logs",
  "db_path": "data/face_db.sqlite",
  "dashboard_port": 5000,
  "enable_dashboard": true,
  "show_preview": true,
  "save_output_video": false,
  "output_video_path": "data/output.avi",
  "insightface_model": "buffalo_sc",
  "insightface_provider": "CPUExecutionProvider",
  "counting_line": {
    "start": [
      0,
      300
    ],
    "end": [
      640,
      300
    ],
    "entry_side": 1
  }
